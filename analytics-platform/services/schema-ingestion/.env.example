# =============================================================================
# Conversational Analytics Platform — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database ----------------------------------------------------------------
METADATA_DB_URL=postgresql+psycopg://ingestion:ingestion@localhost:5442/metadata

# --- Bootstrap Admin ---------------------------------------------------------
# Created automatically on first startup if the DB is empty.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe!SecurePassword123

# --- JWT Auth ----------------------------------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# --- Credential Encryption ---------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Redis / Job Queue -------------------------------------------------------
REDIS_URL=redis://localhost:6380/0

# --- LLM Provider ------------------------------------------------------------
# Options: "mock" (no API key needed), "gemini"
LLM_PROVIDER=mock
GEMINI_API_KEY=

# --- Default Tenant ----------------------------------------------------------
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# =============================================================================
# Phase 6 — Enterprise Multi-Tenancy & Production Security
# =============================================================================

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Secret Backend ----------------------------------------------------------
# "env" = use ENCRYPTION_KEY from this file (default, no extra infra)
# "vault" = use HashiCorp Vault (requires VAULT_* settings below)
SECRET_BACKEND=env

# HashiCorp Vault (only used when SECRET_BACKEND=vault)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-token
VAULT_MOUNT=secret

# --- OIDC / SSO --------------------------------------------------------------
# Set OIDC_ENABLED=true to activate enterprise SSO
OIDC_ENABLED=false
OIDC_PROVIDER_NAME=generic   # azure | google | okta | auth0 | keycloak | generic
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER_URL=
OIDC_REDIRECT_URI=http://localhost:8000/auth/oidc/callback

# Example Azure AD:
# OIDC_PROVIDER_NAME=azure
# OIDC_CLIENT_ID=your-azure-app-client-id
# OIDC_CLIENT_SECRET=your-azure-app-client-secret
# OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0

# Example Google Workspace:
# OIDC_PROVIDER_NAME=google
# OIDC_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# OIDC_CLIENT_SECRET=your-google-client-secret
# OIDC_ISSUER_URL=https://accounts.google.com

# Example Okta:
# OIDC_PROVIDER_NAME=okta
# OIDC_CLIENT_ID=your-okta-client-id
# OIDC_CLIENT_SECRET=your-okta-client-secret
# OIDC_ISSUER_URL=https://your-domain.okta.com

# --- Rate Limiting -----------------------------------------------------------
RATE_LIMIT_CHAT=100/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REFRESH=30/minute

# --- Request Size Limits -----------------------------------------------------
# Maximum allowed request body size in bytes (default: 10MB)
MAX_REQUEST_SIZE_BYTES=10485760

# --- Profiling Guardrails ----------------------------------------------------
PROFILE_SAMPLE_ROWS=10000
PROFILE_TOP_N_VALUES=20
STATEMENT_TIMEOUT_MS=30000
OVERLAP_SAMPLE_VALUES=1000
OVERLAP_MIN_CONFIDENCE=0.90
